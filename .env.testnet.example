# Stellar TestNet config for fhish-stellar. Copy to .env.testnet and fill in.
# Generate + fund a deployer:  stellar keys generate deployer --network testnet --fund
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
DEPLOYER_SECRET=S...your-secret-key...
DEPLOYER_ADDRESS=G...your-public-key...
# Deployed contract ids (from `stellar contract deploy`):
FHE_COPROCESSOR_ID=C...coprocessor...
CONFIDENTIAL_TOKEN_ID=C...token...
